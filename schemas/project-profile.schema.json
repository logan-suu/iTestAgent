{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itestagent.dev/schemas/project-profile.schema.json",
  "title": "ProjectProfile",
  "description": "iTestAgent Project Profile — deterministic + inferred facts about an iOS project. Source: 架构设计文档 §6.1 + 数据流全链路 §5. Stored at ~/.itestagent/projects/<project-hash>/project-profile.json",
  "type": "object",
  "required": ["schemaVersion", "projectHash", "app", "targets", "testAssets", "features", "suggestedSmoke"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Schema version for forward-compat migrations.",
      "const": "itestagent.project-profile.v1"
    },
    "projectHash": {
      "type": "string",
      "description": "sha256(workspace path + git head). Deterministic identifier.",
      "pattern": "^[a-f0-9]{64}$"
    },
    "app": {
      "type": "object",
      "description": "App identity. Deterministic fields from xcodebuild / XcodeProj.",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "bundleId": { "type": "string" },
        "workspace": { "type": "string" },
        "project": { "type": "string" },
        "scheme": { "type": "string" }
      },
      "required": []
    },
    "targets": {
      "type": "array",
      "description": "List of build targets (app/test/extension). Deterministic.",
      "items": {
        "$ref": "#/$defs/TargetProfile"
      }
    },
    "testAssets": {
      "$ref": "#/$defs/TestAssetsProfile"
    },
    "features": {
      "type": "array",
      "description": "Inferred feature candidates. Must carry evidence + confidence (R4: 不自动断定核心链路).",
      "items": {
        "$ref": "#/$defs/FeatureCandidate"
      }
    },
    "suggestedSmoke": {
      "type": "array",
      "description": "Suggested smoke test entry points. Inferred, requires user TUI confirmation.",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "TargetProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["app", "test", "extension", "framework", "watch", "widget"]
        },
        "bundleId": { "type": "string" }
      },
      "required": ["name", "type"]
    },
    "TestAssetsProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hasXCUITest": {
          "type": "boolean",
          "description": "Whether project contains XCUITest targets. Determines execution path (A: xcodebuild test / B: DeviceBackend explore)."
        },
        "hasScheme": {
          "type": "boolean",
          "description": "Whether a test scheme is configured."
        },
        "testTargets": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["hasXCUITest", "hasScheme"]
    },
    "FeatureCandidate": {
      "type": "object",
      "description": "Inferred feature. MUST include evidence + confidence (R4).",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "entry": {
          "type": "string",
          "description": "Entry view/controller class or storyboard."
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "testability": {
          "type": "string",
          "enum": ["xcuitest", "device_backend", "mixed", "unknown"]
        },
        "requiresAccount": {
          "type": "boolean",
          "description": "Whether feature requires user account (affects test data strategy)."
        },
        "evidence": {
          "type": "array",
          "description": "Sources backing this inference. Required (R4).",
          "items": { "type": "string" },
          "minItems": 1
        },
        "confidence": {
          "type": "number",
          "description": "0.0-1.0. <0.5 should be flagged as low-confidence in TUI.",
          "minimum": 0,
          "maximum": 1
        },
        "confirmed": {
          "type": "boolean",
          "description": "Whether the user has confirmed this candidate in the TUI (US-3.3 AC3: only confirmed links enter TestPlan/Flow). Default false.",
          "default": false
        },
        "displayOrder": {
          "type": "integer",
          "description": "User-controlled display ordering; lower = higher priority. Default 0 (insertion order).",
          "minimum": 0,
          "default": 0
        }
      },
      "required": ["name", "evidence", "confidence"]
    }
  }
}
