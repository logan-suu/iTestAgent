{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itestagent.dev/schemas/flow.schema.json",
  "title": "Flow",
  "description": "iTestAgent Flow v2 — replayable test flow YAML. ADR-011: adds supportedTargetKinds, requiredCapabilities, lastValidatedTargets for multi-target flow portability. Source: Architecture Design §6.7. Stored at ~/.itestagent/flows/<flowId>.yaml (YAML-encoded; schema validates the parsed JSON).",
  "type": "object",
  "required": [
    "schemaVersion",
    "flowId",
    "source",
    "status",
    "supportedTargetKinds",
    "requiredCapabilities",
    "lastValidatedTargets",
    "steps"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "itestagent.flow.v2"
    },
    "flowId": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable flow identifier, e.g. login-smoke."
    },
    "source": {
      "type": "string",
      "enum": ["agent-recorded", "user-authored", "imported-draft"],
      "description": "agent-recorded: captured via human-in-the-loop recording (US-8.2/9.1)."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "confirmed", "deprecated"],
      "description": "draft: needs user confirmation before replay. R7: Flow write to project requires confirmation."
    },
    "supportedTargetKinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["physical", "simulator"]
      },
      "description": "Target kinds this flow supports (ADR-011)."
    },
    "requiredCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Normalized backend capabilities required for replay. E.g. uiTree, coordinateTap, swipe, screenshot, textInput. NOT Appium-specific."
    },
    "lastValidatedTargets": {
      "type": "array",
      "items": { "$ref": "#/$defs/ValidatedTarget" },
      "description": "Audit trail of devices that validated this flow. Base data (udid, kind) recorded at compile time; full device info populated lazily by replay engine."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/FlowStep" }
    },
    "notes": {
      "type": "string",
      "description": "Optional human-readable notes about this flow."
    }
  },
  "$defs": {
    "ValidatedTarget": {
      "type": "object",
      "required": ["kind", "udid"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["physical", "simulator"]
        },
        "udid": {
          "type": "string",
          "description": "Device UDID (simulator) or serial (physical)."
        },
        "deviceTypeIdentifier": {
          "type": "string",
          "description": "Simulator: com.apple.CoreSimulator.SimDeviceType.iPhone-15-Pro."
        },
        "runtimeIdentifier": {
          "type": "string",
          "description": "Simulator: com.apple.CoreSimulator.SimRuntime.iOS-18-2."
        },
        "model": {
          "type": "string",
          "description": "Physical: iPhone 14 Plus."
        },
        "osVersion": {
          "type": "string",
          "description": "Physical: 18.2.1."
        }
      }
    },
    "FlowStep": {
      "type": "object",
      "required": ["action"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "launchApp",
            "terminateApp",
            "tap",
            "longPress",
            "swipe",
            "typeText",
            "pressButton",
            "openUrl",
            "screenshot",
            "getUiTree",
            "startRecording",
            "stopRecording",
            "collectLogs",
            "assertVisible",
            "assertNotVisible",
            "assertText",
            "wait",
            "comment"
          ],
          "description": "Normalized action (cross-backend portable). Mirrors DeviceBackend interface plus assertions and flow-control."
        },
        "target": {
          "type": "string",
          "description": "Human-readable target description or locator label."
        },
        "locator": {
          "$ref": "#/$defs/Locator",
          "description": "Normalized element locator (not Appium-specific)."
        },
        "valueRef": {
          "type": "string",
          "description": "Reference to test data. session.secret.* for sensitive data (R6: only in-memory, never persisted)."
        },
        "value": {
          "description": "Inline literal value (for non-sensitive data only)."
        },
        "durationMs": {
          "type": "number",
          "minimum": 0,
          "description": "For wait/longPress/swipe."
        },
        "direction": {
          "type": "string",
          "enum": ["up", "down", "left", "right"]
        },
        "expectedText": {
          "type": "string",
          "description": "For assertText."
        },
        "comment": {
          "type": "string",
          "description": "For comment action or unmapped actions."
        },
        "safetyGate": {
          "type": "string",
          "enum": ["allow", "ask", "deny"],
          "description": "Safety gate for irreversible operations (R7)."
        }
      }
    },
    "Locator": {
      "type": "object",
      "required": ["strategy", "value"],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["label", "identifier", "xpath", "coordinate", "image"]
        },
        "value": { "type": "string" }
      }
    }
  }
}
